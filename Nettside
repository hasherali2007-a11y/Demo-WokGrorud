<!DOCTYPE html>
<html lang="no">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Asian Wok & Cafe – Autentisk Asiatisk Mat på Grorud, Oslo</title>
<meta name="description" content="Asian Wok & Cafe på Grorud, Oslo – Ferske wok-retter, pad thai, kinesiske klassikere og thai favoritter. Ring 21 38 02 11. Bergensveien 2, 0963 Oslo.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;700;900&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #0a0806;
    --deep: #110d09;
    --surface: #1a1209;
    --card: #1e1610;
    --border: rgba(255,160,40,0.15);
    --red: #e8360a;
    --orange: #ff7020;
    --neon: #ff6010;
    --gold: #c9962a;
    --gold-light: #f0c060;
    --cream: #f5e8c8;
    --text: #e8dcc8;
    --muted: #8a7a60;
    --glow-red: rgba(232,54,10,0.4);
    --glow-gold: rgba(201,150,42,0.3);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    overflow-x: hidden;
    cursor: default;
  }

  /* ===== BACKGROUND TEXTURE ===== */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      radial-gradient(ellipse 80% 50% at 20% 10%, rgba(232,54,10,0.06) 0%, transparent 60%),
      radial-gradient(ellipse 60% 40% at 80% 80%, rgba(201,150,42,0.05) 0%, transparent 50%),
      url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23c9962a' fill-opacity='0.02'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
  }

  /* ===== STEAM ANIMATION ===== */
  @keyframes steam {
    0% { transform: translateY(0) scaleX(1) rotate(0deg); opacity: 0; }
    20% { opacity: 0.6; }
    80% { opacity: 0.2; }
    100% { transform: translateY(-120px) scaleX(1.8) rotate(8deg); opacity: 0; }
  }
  @keyframes steam2 {
    0% { transform: translateY(0) scaleX(1) rotate(0deg); opacity: 0; }
    20% { opacity: 0.5; }
    80% { opacity: 0.15; }
    100% { transform: translateY(-100px) scaleX(2.2) rotate(-6deg); opacity: 0; }
  }
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-12px); }
  }
  @keyframes glow-pulse {
    0%, 100% { box-shadow: 0 0 20px var(--glow-red), 0 0 40px rgba(232,54,10,0.2); }
    50% { box-shadow: 0 0 35px var(--glow-red), 0 0 70px rgba(232,54,10,0.3); }
  }
  @keyframes neon-flicker {
    0%, 95%, 100% { opacity: 1; text-shadow: 0 0 10px var(--neon), 0 0 30px var(--neon), 0 0 60px rgba(255,96,16,0.5); }
    96% { opacity: 0.7; text-shadow: none; }
    97% { opacity: 1; text-shadow: 0 0 10px var(--neon), 0 0 30px var(--neon); }
    98% { opacity: 0.8; }
  }
  @keyframes slideInDown {
    from { transform: translateY(-30px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
  @keyframes fadeInUp {
    from { transform: translateY(40px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
  @keyframes scaleIn {
    from { transform: scale(0.9); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }
  @keyframes shimmer {
    0% { background-position: -200% center; }
    100% { background-position: 200% center; }
  }
  @keyframes rotate-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* ===== NAVBAR ===== */
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 0 5%;
    height: 70px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(10,8,6,0.85);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    animation: slideInDown 0.6s ease;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
  }

  .nav-logo-icon {
    width: 42px;
    height: 42px;
    background: linear-gradient(135deg, var(--red), var(--gold));
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    box-shadow: 0 0 15px var(--glow-red);
    flex-shrink: 0;
  }

  .nav-logo-text {
    font-family: 'Noto Serif SC', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--cream);
    line-height: 1.2;
  }

  .nav-logo-sub {
    font-size: 0.65rem;
    color: var(--gold);
    letter-spacing: 2px;
    text-transform: uppercase;
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }

  .nav-links a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.5px;
    transition: color 0.3s;
    position: relative;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--neon);
    transform: scaleX(0);
    transition: transform 0.3s;
    box-shadow: 0 0 6px var(--neon);
  }

  .nav-links a:hover { color: var(--cream); }
  .nav-links a:hover::after { transform: scaleX(1); }

  .nav-cta {
    background: linear-gradient(135deg, var(--red), var(--orange));
    color: white !important;
    padding: 8px 20px;
    border-radius: 6px;
    font-weight: 600 !important;
    transition: all 0.3s !important;
    box-shadow: 0 0 15px var(--glow-red);
  }

  .nav-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 25px var(--glow-red) !important;
  }

  .nav-cta::after { display: none !important; }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 4px;
    background: none;
    border: none;
  }

  .hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--cream);
    border-radius: 2px;
    transition: all 0.3s;
  }

  /* ===== HERO ===== */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 70px 5% 0;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 120% 80% at 50% 100%, rgba(232,54,10,0.12) 0%, transparent 60%),
      radial-gradient(ellipse 80% 60% at 80% 20%, rgba(201,150,42,0.08) 0%, transparent 50%),
      linear-gradient(180deg, var(--black) 0%, #120a05 100%);
  }

  /* Decorative Asian pattern overlay */
  .hero-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg width='120' height='120' viewBox='0 0 120 120' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23f0c060' fill-rule='evenodd'%3E%3Ccircle cx='60' cy='60' r='4'/%3E%3Ccircle cx='60' cy='60' r='20' fill='none' stroke='%23f0c060' stroke-width='1'/%3E%3Ccircle cx='60' cy='60' r='40' fill='none' stroke='%23f0c060' stroke-width='0.5'/%3E%3Cpath d='M60 20 L80 40 L60 60 L40 40 Z' fill='none' stroke='%23f0c060' stroke-width='0.5'/%3E%3C/g%3E%3C/svg%3E");
    pointer-events: none;
  }

  /* Steam elements */
  .steam-container {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 200px;
    pointer-events: none;
    overflow: hidden;
  }

  .steam-puff {
    position: absolute;
    bottom: 0;
    width: 40px;
    height: 60px;
    background: radial-gradient(ellipse, rgba(255,160,80,0.15) 0%, transparent 70%);
    border-radius: 50%;
    filter: blur(8px);
  }

  .steam-puff:nth-child(1) { left: 20%; animation: steam 4s ease-in-out infinite; }
  .steam-puff:nth-child(2) { left: 35%; animation: steam2 3.5s ease-in-out infinite 0.8s; }
  .steam-puff:nth-child(3) { left: 50%; animation: steam 5s ease-in-out infinite 1.5s; }
  .steam-puff:nth-child(4) { left: 65%; animation: steam2 4s ease-in-out infinite 0.3s; }
  .steam-puff:nth-child(5) { left: 80%; animation: steam 3.8s ease-in-out infinite 2s; }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 900px;
    animation: fadeInUp 1s ease 0.3s both;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(232,54,10,0.15);
    border: 1px solid rgba(232,54,10,0.4);
    border-radius: 100px;
    padding: 6px 18px;
    font-size: 0.8rem;
    color: var(--orange);
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 2rem;
    font-weight: 500;
  }

  .hero-badge::before { content: '🍜'; }

  .hero-title {
    font-family: 'Noto Serif SC', serif;
    font-size: clamp(2.8rem, 7vw, 6rem);
    font-weight: 900;
    line-height: 1.05;
    color: var(--cream);
    margin-bottom: 1.5rem;
  }

  .hero-title .highlight {
    color: transparent;
    background: linear-gradient(135deg, var(--orange) 0%, var(--gold-light) 50%, var(--orange) 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    animation: shimmer 3s linear infinite;
    display: block;
  }

  .hero-sub {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--muted);
    max-width: 560px;
    margin: 0 auto 3rem;
    line-height: 1.7;
    font-weight: 300;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--red), var(--orange));
    color: white;
    padding: 16px 36px;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.3s;
    animation: glow-pulse 2.5s ease-in-out infinite;
    border: none;
    cursor: pointer;
    letter-spacing: 0.3px;
  }

  .btn-primary:hover {
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 8px 30px var(--glow-red);
  }

  .btn-secondary {
    background: transparent;
    color: var(--cream);
    padding: 15px 36px;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 500;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(240,192,96,0.4);
    transition: all 0.3s;
    letter-spacing: 0.3px;
  }

  .btn-secondary:hover {
    border-color: var(--gold);
    color: var(--gold-light);
    background: rgba(201,150,42,0.08);
    transform: translateY(-2px);
  }

  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    color: var(--muted);
    font-size: 0.75rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    animation: float 2.5s ease-in-out infinite;
  }

  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--gold), transparent);
  }

  /* ===== SECTIONS ===== */
  section {
    position: relative;
    z-index: 1;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .section-label {
    font-size: 0.75rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 0.75rem;
    font-weight: 500;
  }

  .section-title {
    font-family: 'Noto Serif SC', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--cream);
    line-height: 1.2;
  }

  .section-title .gold { color: var(--gold-light); }

  .section-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 1.2rem;
  }

  .section-divider::before,
  .section-divider::after {
    content: '';
    width: 60px;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--gold));
  }

  .section-divider::after {
    background: linear-gradient(to left, transparent, var(--gold));
  }

  .section-divider span { color: var(--gold); font-size: 1rem; }

  /* ===== POPULAR DISHES ===== */
  #populaere {
    padding: 100px 5%;
    background: linear-gradient(180deg, var(--black) 0%, var(--deep) 100%);
  }

  .dishes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  .dish-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.4,0,0.2,1);
    position: relative;
    animation: scaleIn 0.6s ease both;
  }

  .dish-card:hover {
    transform: translateY(-8px);
    border-color: rgba(255,112,32,0.4);
    box-shadow: 0 20px 50px rgba(0,0,0,0.5), 0 0 30px rgba(232,54,10,0.15);
  }

  .dish-img-wrap {
    position: relative;
    height: 220px;
    overflow: hidden;
  }

  .dish-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .dish-card:hover .dish-img { transform: scale(1.08); }

  .dish-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 5rem;
    position: relative;
  }

  .dish-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10,8,6,0.8) 0%, transparent 60%);
  }

  .spicy-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    background: rgba(232,54,10,0.9);
    border-radius: 100px;
    padding: 4px 10px;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: white;
    display: flex;
    align-items: center;
    gap: 4px;
    backdrop-filter: blur(4px);
  }

  .dish-body {
    padding: 1.25rem 1.5rem 1.5rem;
  }

  .dish-name {
    font-family: 'Libre Baskerville', serif;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--cream);
    margin-bottom: 0.4rem;
  }

  .dish-desc {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .dish-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .dish-price {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--gold-light);
    font-family: 'Libre Baskerville', serif;
  }

  .dish-price span {
    font-size: 0.9rem;
    color: var(--muted);
    font-weight: 400;
    font-family: 'DM Sans', sans-serif;
  }

  .add-btn {
    width: 38px;
    height: 38px;
    background: linear-gradient(135deg, var(--red), var(--orange));
    border: none;
    border-radius: 50%;
    color: white;
    font-size: 1.3rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s;
    box-shadow: 0 0 12px var(--glow-red);
    flex-shrink: 0;
  }

  .add-btn:hover {
    transform: scale(1.15) rotate(90deg);
    box-shadow: 0 0 20px var(--glow-red);
  }

  /* ===== FULL MENU ===== */
  #meny {
    padding: 100px 5%;
    background: var(--deep);
    position: relative;
  }

  #meny::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--border) 20%, var(--border) 80%, transparent);
  }

  .menu-tabs {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 3rem;
    max-width: 1000px;
    margin-left: auto;
    margin-right: auto;
  }

  .menu-tab {
    background: var(--card);
    border: 1px solid var(--border);
    color: var(--muted);
    padding: 10px 20px;
    border-radius: 100px;
    font-size: 0.88rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s;
    white-space: nowrap;
  }

  .menu-tab:hover {
    color: var(--cream);
    border-color: rgba(255,112,32,0.3);
  }

  .menu-tab.active {
    background: linear-gradient(135deg, rgba(232,54,10,0.3), rgba(255,112,32,0.2));
    border-color: var(--orange);
    color: var(--cream);
    box-shadow: 0 0 15px rgba(255,112,32,0.2);
  }

  .menu-section {
    display: none;
    max-width: 1000px;
    margin: 0 auto;
    animation: fadeInUp 0.4s ease;
  }

  .menu-section.active { display: block; }

  .menu-items {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .menu-item {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    padding: 1.2rem 1.5rem;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    margin-bottom: 0.5rem;
    transition: all 0.3s;
    align-items: start;
  }

  .menu-item:hover {
    border-color: rgba(255,112,32,0.3);
    background: rgba(30,22,16,0.8);
    transform: translateX(4px);
  }

  .menu-item-name {
    font-family: 'Libre Baskerville', serif;
    font-size: 1rem;
    color: var(--cream);
    margin-bottom: 0.3rem;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .menu-item-desc {
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.5;
  }

  .menu-item-price {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--gold-light);
    white-space: nowrap;
    font-family: 'Libre Baskerville', serif;
  }

  .hot-tag {
    font-size: 0.7rem;
    background: rgba(232,54,10,0.2);
    border: 1px solid rgba(232,54,10,0.4);
    color: var(--orange);
    padding: 2px 7px;
    border-radius: 4px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  /* ===== ABOUT ===== */
  #om {
    padding: 100px 5%;
    background: linear-gradient(180deg, var(--deep) 0%, var(--surface) 100%);
  }

  .about-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .about-visual {
    position: relative;
  }

  .about-main-img {
    width: 100%;
    border-radius: 20px;
    background: var(--card);
    border: 1px solid var(--border);
    height: 480px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 8rem;
    position: relative;
    overflow: hidden;
  }

  .about-main-img::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 80%, rgba(232,54,10,0.12) 0%, transparent 70%);
  }

  .about-float-card {
    position: absolute;
    bottom: -20px;
    right: -20px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.2rem 1.5rem;
    backdrop-filter: blur(10px);
    animation: float 3s ease-in-out infinite;
  }

  .about-float-card .num {
    font-family: 'Libre Baskerville', serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--gold-light);
    line-height: 1;
  }

  .about-float-card .label {
    font-size: 0.8rem;
    color: var(--muted);
    margin-top: 4px;
  }

  .about-text h2 {
